<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_l10n_in_edi_custom" model="ir.ui.view">
        <field name="name">account.move.form.inherit.l10n.in.edi.custom</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Rename Create e-Waybill to Create e-Invoice only for Customer Invoices -->
            <xpath expr="//button[@name='action_l10n_in_ewaybill_create']" position="attributes">
                <attribute name="string">Create e-Invoice</attribute>
                <attribute name="invisible">move_type != 'out_invoice' or country_code != 'IN' or not l10n_in_ewaybill_feature_enabled or state != 'posted' or l10n_in_ewaybill_ids</attribute>
            </xpath>

            <!-- Keep Create e-Waybill for other documents (like Vendor Bills) -->
            <xpath expr="//button[@name='action_l10n_in_ewaybill_create']" position="after">
                <button name="action_l10n_in_ewaybill_create" 
                        string="Create e-Waybill"
                        class="oe_highlight"
                        type="object"
                        invisible="move_type == 'out_invoice' or country_code != 'IN' or not l10n_in_ewaybill_feature_enabled or state != 'posted' or l10n_in_ewaybill_ids"
                        groups="account.group_account_invoice"
                        data-hotkey="e"/>
            </xpath>
        </field>
    </record>
</odoo>
