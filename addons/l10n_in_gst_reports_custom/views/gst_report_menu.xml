<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_l10n_in_gst_report_line_tree" model="ir.ui.view">
        <field name="name">l10n_in.gst.report.line.tree</field>
        <field name="model">l10n_in.gst.report.line</field>
        <field name="arch" type="xml">
            <list string="Report Lines" create="0" edit="0" delete="0">
                <field name="particulars"/>
                <field name="vch_count"/>
                <field name="taxable_amount" sum="Total"/>
                <field name="igst" sum="Total"/>
                <field name="cgst" sum="Total"/>
                <field name="sgst" sum="Total"/>
                <field name="cess" sum="Total"/>
                <field name="tax_amount" sum="Total"/>
                <field name="invoice_amount" sum="Total"/>
            </list>
        </field>
    </record>

    <record id="view_l10n_in_gst_report_wizard_form" model="ir.ui.view">
        <field name="name">l10n_in.gst.report.wizard.form</field>
        <field name="model">l10n_in.gst.report.wizard</field>
        <field name="arch" type="xml">
            <form string="GST Report Wizard">
                <group>
                    <group>
                        <field name="report_type"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                </group>
                <group string="Voucher Statistics" invisible="not total_vouchers">
                    <group>
                        <field name="total_vouchers"/>
                        <field name="included_vouchers"/>
                        <field name="excluded_vouchers"/>
                    </group>
                </group>
                <footer>
                    <button name="action_view_report" string="View Report" type="object" class="btn-primary"/>
                    <button name="action_generate_excel" string="Download Excel" type="object" class="btn-secondary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
                <notebook invisible="not line_ids">
                    <page string="Report Preview">
                        <field name="line_ids" readonly="1"/>
                    </page>
                </notebook>
            </form>
        </field>
    </record>

    <record id="action_l10n_in_gst_report_wizard" model="ir.actions.act_window">
        <field name="name">GST Reports (GSTR-1/3B)</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">l10n_in.gst.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_l10n_in_gst_reports"
              name="GST Reports (Custom)"
              parent="account.menu_finance_reports"
              action="action_l10n_in_gst_report_wizard"
              sequence="10"/>
</odoo>
