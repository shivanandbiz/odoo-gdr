<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gstr7_report_wizard_form" model="ir.ui.view">
        <field name="name">gstr7.report.wizard.form</field>
        <field name="model">gstr7.report.wizard</field>
        <field name="arch" type="xml">
            <form string="GSTR-7 TDS Report">
                <group>
                    <group>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                </group>
                <group string="Configuration">
                    <field name="tds_tax_ids" widget="many2many_tags" options="{'no_create': True}"/>
                </group>
                <footer>
                    <button name="action_generate_report" string="Generate Excel Final" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_gstr7_report_wizard" model="ir.actions.act_window">
        <field name="name">GSTR-7 Report</field>
        <field name="res_model">gstr7.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_gstr7_report" 
              name="GSTR-7 Report" 
              parent="account.account_reports_management_menu" 
              action="action_gstr7_report_wizard" 
              sequence="202"/>
</odoo>
