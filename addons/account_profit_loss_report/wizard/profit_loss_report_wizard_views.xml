<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_profit_loss_wizard_form" model="ir.ui.view">
        <field name="name">account.profit.loss.wizard.form</field>
        <field name="model">account.profit.loss.wizard</field>
        <field name="arch" type="xml">
            <form string="Profit and Loss Report">
                <group>
                    <group>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                </group>
                <footer>
                    <button name="action_generate_report" string="Generate Excel Report" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_account_profit_loss_wizard" model="ir.actions.act_window">
        <field name="name">Profit &amp; Loss Excel Report</field>
        <field name="res_model">account.profit.loss.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_account_profit_loss_report" 
              name="Profit &amp; Loss (Excel)" 
              parent="account.account_reports_management_menu" 
              action="action_account_profit_loss_wizard" 
              sequence="200"/>
</odoo>
