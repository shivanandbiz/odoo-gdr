<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Bulk Payment wizard menu under Vendors -->
    <menuitem id="menu_multi_bill_payment"
              name="Bulk Payment"
              parent="account.menu_finance_payables"
              action="action_multi_bill_payment"
              sequence="20"/>

    <!-- Vendor Advances -->
    <record id="action_vendor_advances" model="ir.actions.act_window">
        <field name="name">Vendor Advances</field>
        <field name="res_model">account.payment</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('partner_type', '=', 'supplier'), ('payment_type', '=', 'outbound')]</field>
        <field name="context">{'default_partner_type': 'supplier', 'default_payment_type': 'outbound'}</field>
    </record>

    <menuitem id="menu_vendor_advances"
              name="Vendor Advances"
              parent="account.menu_finance_payables"
              action="action_vendor_advances"
              sequence="30"/>
</odoo>
