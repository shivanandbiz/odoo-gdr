<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_move_reversal_inherit" model="ir.ui.view">
        <field name="name">account.move.reversal.form.inherit</field>
        <field name="model">account.move.reversal</field>
        <field name="inherit_id" ref="account.view_account_move_reversal"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='journal_id']" position="after">
                <field name="l10n_in_gst_reason"/>
            </xpath>
            
            <xpath expr="//group" position="after">
                <notebook>
                    <page string="Item Selection (Debit/Credit Note)">
                        <field name="reversal_line_ids">
                            <list editable="bottom" create="false" delete="false">
                                <field name="move_line_id" column_invisible="True"/>
                                <field name="product_id"/>
                                <field name="name"/>
                                <field name="original_quantity"/>
                                <field name="quantity" string="Qty to Reverse"/>
                                <field name="price_unit"/>
                                <field name="tax_ids" widget="many2many_tags"/>
                            </list>
                        </field>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>
</odoo>
