<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mrp_mps_tree" model="ir.ui.view">
        <field name="name">mrp.mps.tree</field>
        <field name="model">mrp.mps</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="product_id"/>
                <field name="date"/>
                <field name="forecast_qty"/>
                <field name="actual_qty"/>
            </list>
        </field>
    </record>
    <record id="action_mrp_mps" model="ir.actions.act_window">
        <field name="name">Master Production Schedule</field>
        <field name="res_model">mrp.mps</field>
        <field name="view_mode">list</field>
    </record>
    <menuitem id="menu_mrp_mps" name="Master Production Schedule" parent="mrp.mrp_planning_menu_root" action="action_mrp_mps" sequence="10"/>
    <record id="res_config_settings_view_form_inherit_mps" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.mps</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="mrp.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='module_mrp_mps']" position="attributes">
                <attribute name="widget"/>
            </xpath>
        </field>
    </record>
</odoo>
