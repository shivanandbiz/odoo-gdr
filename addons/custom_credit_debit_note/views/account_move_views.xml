<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_custom_credit_debit" model="ir.ui.view">
        <field name="name">account.move.form.inherit.custom.credit.debit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_reference']" position="after">
                <field name="l10n_in_gst_reason" readonly="state != 'draft'" invisible="move_type not in ('out_refund', 'in_refund') and not debit_origin_id"/>
            </xpath>
        </field>
    </record>
</odoo>
