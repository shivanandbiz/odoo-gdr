<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_line_tree_gdr_closing" model="ir.ui.view">
        <field name="name">account.move.line.tree.gdr.closing</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_tree"/>
        <field name="arch" type="xml">
            <!-- Add our custom closing balance column with sum aggregator -->
            <xpath expr="//field[@name='credit']" position="after">
                <field name="gdr_closing_balance" sum="Closing Balance" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
