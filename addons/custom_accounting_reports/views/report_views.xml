<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_custom_report_wizard_form" model="ir.ui.view">
        <field name="name">custom.report.wizard.form</field>
        <field name="model">custom.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Report Parameters">
                <group>
                    <field name="report_type" invisible="1"/>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group>
                        <field name="target_move"/>
                        <field name="journal_id" invisible="report_type != 'brs_statement'" required="report_type == 'brs_statement'"/>
                    </group>
                </group>
                <footer>
                    <button name="action_view_report" string="View Report" type="object" class="btn-primary"/>
                    <button name="action_generate_excel" string="Download Excel" type="object" class="btn-secondary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Specific List Views for Report Display -->
    <record id="view_brs_statement_display_tree" model="ir.ui.view">
        <field name="name">custom.brs.statement.display.list</field>
        <field name="model">custom.report.display.line</field>
        <field name="arch" type="xml">
            <list string="Bank Reconciliation Statement" create="0" edit="0" delete="0">
                <field name="date"/>
                <field name="ref" string="Voucher No / Ref"/>
                <field name="name" string="Particulars / Description"/>
                <field name="debit" sum="Total Debit"/>
                <field name="credit" sum="Total Credit"/>
                <field name="balance" string="Balance"/>
                <field name="invoice_status_amount" string="Status"/>
            </list>
        </field>
    </record>

    <record id="view_balance_sheet_display_tree" model="ir.ui.view">
