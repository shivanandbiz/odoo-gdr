<odoo>
    <record id="view_bank_statement_line_tree_reconcile" model="ir.ui.view">
        <field name="name">account.bank.statement.line.tree.reconcile</field>
        <field name="model">account.bank.statement.line</field>
        <field name="arch" type="xml">
            <list string="Bank Transactions" create="false" edit="false">
                <field name="date"/>
                <field name="payment_ref"/>
                <field name="partner_id"/>
                <field name="amount"/>
                <field name="running_balance"/>
                <field name="is_reconciled"/>
                <button name="action_undo_reconciliation" type="object" string="Undo" icon="fa-undo" invisible="not is_reconciled"/>
            </list>
        </field>
    </record>

    <record id="view_bank_statement_line_form_reconcile" model="ir.ui.view">
        <field name="name">account.bank.statement.line.form.reconcile</field>
        <field name="model">account.bank.statement.line</field>
        <field name="arch" type="xml">
            <form string="Bank Transaction">
                <header>
                    <button name="action_undo_reconciliation" type="object" string="Undo Reconciliation" invisible="not is_reconciled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="payment_ref"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="journal_id" readonly="1"/>
                            <field name="is_reconciled" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_bank_statement_line_search_reconcile" model="ir.ui.view">
        <field name="name">account.bank.statement.line.search.reconcile</field>
        <field name="model">account.bank.statement.line</field>
        <field name="arch" type="xml">
            <search string="Search Bank Transactions">
                <field name="payment_ref"/>
                <field name="partner_id"/>
                <filter string="To Reconcile" name="to_reconcile" domain="[('is_reconciled', '=', False)]"/>
                <filter string="Reconciled" name="reconciled" domain="[('is_reconciled', '=', True)]"/>
            </search>
        </field>
    </record>

    <record id="action_bank_statement_line_reconcile" model="ir.actions.act_window">
        <field name="name">Reconcile Transactions</field>
        <field name="res_model">account.bank.statement.line</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_bank_statement_line_search_reconcile"/>
        <field name="context">{'search_default_to_reconcile': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No transactions to reconcile!
            </p>
        </field>
    </record>

    <menuitem id="menu_bank_reconcile"
              name="Reconciliation"
              parent="account.menu_finance_entries"
              action="action_bank_statement_line_reconcile"
              sequence="10"/>
</odoo>
