<odoo>
    <record id="view_bank_statement_import_wizard" model="ir.ui.view">
        <field name="name">custom.bank.statement.import.form</field>
        <field name="model">custom.bank.statement.import</field>
        <field name="arch" type="xml">
            <form string="Import Bank Statement">
                <sheet>
                    <group>
                        <group string="Import Settings">
                            <field name="journal_id" options="{'no_create': True}"/>
                            <field name="import_file" filename="filename" widget="binary"/>
                            <field name="filename" invisible="1"/>
                        </group>
                        <group string="CSV Format Instructions">
                            <div class="text-muted" colspan="2">
                                <p><strong>Required columns (case-insensitive):</strong></p>
                                <ul>
                                    <li><strong>Date:</strong> date, transaction date, value date</li>
                                    <li><strong>Description:</strong> description, label, narration, particulars</li>
                                    <li><strong>Amount:</strong> amount (positive=inflow, negative=outflow)<br/>
                                        OR separate <strong>Debit</strong> and <strong>Credit</strong> columns</li>
                                </ul>
                                <p><strong>Supported date formats:</strong> DD/MM/YYYY, YYYY-MM-DD, DD-MM-YYYY</p>
                            </div>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_import" string="Import" type="object" class="btn btn-primary"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_bank_statement_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Bank Statement</field>
        <field name="res_model">custom.bank.statement.import</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
